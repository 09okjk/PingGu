{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirement-output.schema.json",
  "title": "ParseRequirementSkill Output",
  "type": "object",
  "required": ["success", "data", "error"],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": ["object", "null"],
      "properties": {
        "input_type": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "requirement_count": {
          "type": "integer",
          "minimum": 0
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "requirement_id",
              "summary",
              "original_evidence",
              "ambiguities",
              "confidence",
              "needs_user_confirmation"
            ],
            "properties": {
              "requirement_id": { "type": "string" },
              "summary": { "type": "string" },
              "business_type": {
                "type": ["object", "null"],
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "name": { "type": ["string", "null"] },
                  "confidence": { "type": "string" }
                },
                "required": ["code", "name", "confidence"]
              },
              "service_desc": {
                "type": ["object", "null"],
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "name": { "type": ["string", "null"] },
                  "confidence": { "type": "string" }
                }
              },
              "service_type": {
                "type": ["object", "null"],
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "name": { "type": ["string", "null"] },
                  "confidence": { "type": "string" }
                }
              },
              "equipment_name": {
                "type": ["object", "null"],
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "name": { "type": ["string", "null"] },
                  "confidence": { "type": "string" }
                }
              },
              "equipment_model": {
                "type": ["object", "null"],
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "name": { "type": ["string", "null"] },
                  "confidence": { "type": "string" }
                }
              },
              "equipment_manufacturer": {
                "type": ["string", "null"]
              },
              "equipment_quantity": {
                "type": ["number", "null"]
              },
              "equipment_unit": {
                "type": ["object", "null"],
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "name": { "type": ["string", "null"] },
                  "confidence": { "type": "string" }
                }
              },
              "service_device_models": {
                "type": "array",
                "items": { "type": "string" }
              },
              "remark": {
                "type": ["string", "null"]
              },
              "original_evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "ambiguities": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": { "type": "string" },
                    "reason": { "type": "string" },
                    "candidates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": { "type": ["string", "null"] },
                          "name": { "type": ["string", "null"] }
                        }
                      }
                    }
                  },
                  "required": ["field", "reason", "candidates"]
                }
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "needs_user_confirmation": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          }
        },
        "global_ambiguities": {
          "type": "array",
          "items": { "type": "object" }
        },
        "parsing_notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metadata": {
          "type": ["object", "null"],
          "additionalProperties": true
        }
      },
      "required": [
        "input_type",
        "language",
        "requirement_count",
        "requirements",
        "global_ambiguities",
        "parsing_notes"
      ],
      "additionalProperties": true
    },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "required": ["code", "message"]
    }
  },
  "additionalProperties": false
}