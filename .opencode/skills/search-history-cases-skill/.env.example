# ======================================
# 智能评估 Agent - 数据库配置模板
# ======================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置
# 3. 生产环境请使用 .env.prod 文件
# ======================================

# 当前环境标识 (dev / test / prod)
APP_ENV=dev

# ======================================
# 开发环境数据库配置
# ======================================
PGHOST_DEV=192.168.124.126
PGPORT_DEV=5432
PGDATABASE_DEV=pinggu_dev
PGUSER_DEV=postgres
PGPASSWORD_DEV=wk888

# ======================================
# 测试环境数据库配置
# ======================================
PGHOST_TEST=192.168.124.126
PGPORT_TEST=5432
PGDATABASE_TEST=pinggu_test
PGUSER_TEST=postgres
PGPASSWORD_TEST=your_test_password

# ======================================
# 生产环境数据库配置
# ======================================
# ⚠️ 生产配置不应提交到版本控制系统
PGHOST_PROD=10.0.0.100
PGPORT_PROD=5432
PGDATABASE_PROD=pinggu_prod
PGUSER_PROD=pinggu_app
PGPASSWORD_PROD=your_secure_password

# ======================================
# 当前使用的数据库配置（根据 APP_ENV 自动切换）
# ======================================
# 以下配置由脚本自动设置，无需手动修改
# 如要手动指定，请取消注释并修改：
# PGHOST=${PGHOST_DEV}
# PGPORT=${PGPORT_DEV}
# PGDATABASE=${PGDATABASE_DEV}
# PGUSER=${PGUSER_DEV}
# PGPASSWORD=${PGPASSWORD_DEV}
