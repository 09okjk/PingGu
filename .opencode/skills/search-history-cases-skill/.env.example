# ======================================
# S1 - SearchHistoryCasesSkill 环境配置
# ======================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env (Linux/Mac) 或 copy .env.example .env (Windows)
# 2. 根据实际环境修改数据库配置
# 3. .env 文件已加入 .gitignore，不会被提交到版本控制
# ======================================

# PostgreSQL 数据库连接配置
PGHOST=192.168.124.126      # 数据库主机地址
PGPORT=5432                 # 数据库端口
PGDATABASE=pinggu           # 数据库名称
PGUSER=postgres             # 数据库用户名
PGPASSWORD=your_password    # 数据库密码（请修改为实际密码）
PGSSLMODE=disable           # SSL 模式：disable / require / verify-ca / verify-full
