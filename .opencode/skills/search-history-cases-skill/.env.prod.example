# ======================================
# 智能评估 Agent - 生产环境配置
# ======================================
# ⚠️ 重要安全提示：
# 1. 此文件包含生产环境敏感信息
# 2. 不应提交到版本控制系统
# 3. 文件权限应设置为 600
# 4. 仅部署在生产服务器上
# ======================================

# 当前环境标识
APP_ENV=prod

# ======================================
# S1 - 历史检索技能数据库配置
# ======================================
PGHOST_PROD=<生产数据库 IP>
PGPORT_PROD=5432
PGDATABASE_PROD=pinggu_prod
PGUSER_PROD=pinggu_app
PGPASSWORD_PROD=<生产数据库密码>
PGSSLMODE_PROD=require

# ======================================
# S2 - 评估推理技能数据库配置
# ======================================
PINGGU_USE_DB=true
PINGGU_DB_HOST_PROD=<生产数据库 IP>
PINGGU_DB_PORT_PROD=5432
PINGGU_DB_NAME_PROD=pinggu_prod
PINGGU_DB_USER_PROD=pinggu_app
PINGGU_DB_PASSWORD_PROD=<生产数据库密码>
PINGGU_DB_SSLMODE_PROD=require

# ======================================
# 当前使用的配置（自动切换到生产环境）
# ======================================
PGHOST=${PGHOST_PROD}
PGPORT=${PGPORT_PROD}
PGDATABASE=${PGDATABASE_PROD}
PGUSER=${PGUSER_PROD}
PGPASSWORD=${PGPASSWORD_PROD}
PGSSLMODE=${PGSSLMODE_PROD}

PINGGU_DB_HOST=${PINGGU_DB_HOST_PROD}
PINGGU_DB_PORT=${PINGGU_DB_PORT_PROD}
PINGGU_DB_NAME=${PINGGU_DB_NAME_PROD}
PINGGU_DB_USER=${PINGGU_DB_USER_PROD}
PINGGU_DB_PASSWORD=${PINGGU_DB_PASSWORD_PROD}
PINGGU_DB_SSLMODE=${PINGGU_DB_SSLMODE_PROD}
