# ======================================
# S2 - AssessmentReasoningSkill 环境配置
# ======================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env (Linux/Mac) 或 copy .env.example .env (Windows)
# 2. 根据实际环境修改数据库配置
# 3. .env 文件已加入 .gitignore，不会被提交到版本控制
# ======================================

# 是否启用 PostgreSQL 数据库模式
# true = 从数据库读取参考数据（推荐多用户/生产环境）
# false = 从本地 references 目录读取（推荐单机测试/离线环境）
PINGGU_USE_DB=false

# PostgreSQL 连接配置（仅在 PINGGU_USE_DB=true 时使用）
PINGGU_DB_HOST=192.168.124.126      # 数据库主机地址
PINGGU_DB_PORT=5432                 # 数据库端口
PINGGU_DB_NAME=pinggu               # 数据库名称
PINGGU_DB_USER=postgres             # 数据库用户名
PINGGU_DB_PASSWORD=your_password    # 数据库密码（请修改为实际密码）
PINGGU_DB_SSLMODE=disable           # SSL 模式：disable / require / verify-ca / verify-full
