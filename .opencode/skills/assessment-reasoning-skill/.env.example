# 是否启用 PostgreSQL 数据库模式（推荐：true）
# 生产环境应设置为 true，从数据库读取规则
# 仅在离线调试时临时设置为 false
PINGGU_USE_DB=true

# PostgreSQL 连接配置
PINGGU_DB_HOST=192.168.124.126
PINGGU_DB_PORT=5432
PINGGU_DB_NAME=pinggu
PINGGU_DB_USER=postgres
PINGGU_DB_PASSWORD=wk888

# 可选：SSL 模式（disable / require / verify-ca / verify-full）
PINGGU_DB_SSLMODE=disable

# 数据库连接池配置（可选）
PINGGU_DB_POOL_MIN=1
PINGGU_DB_POOL_MAX=10
