# ======================================
# 智能评估 Agent - S2 数据库配置模板
# ======================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置
# 3. 生产环境请使用 .env.prod 文件
# ======================================

# 当前环境标识 (dev / test / prod)
APP_ENV=dev

# 是否启用 PostgreSQL 数据库模式（推荐：true）
# 生产环境应设置为 true，从数据库读取规则
# 仅在离线调试时临时设置为 false
PINGGU_USE_DB=true

# ======================================
# 开发环境数据库配置
# ======================================
PINGGU_DB_HOST_DEV=192.168.124.126
PINGGU_DB_PORT_DEV=5432
PINGGU_DB_NAME_DEV=pinggu_dev
PINGGU_DB_USER_DEV=postgres
PINGGU_DB_PASSWORD_DEV=wk888
PINGGU_DB_SSLMODE_DEV=disable

# ======================================
# 测试环境数据库配置
# ======================================
PINGGU_DB_HOST_TEST=192.168.124.126
PINGGU_DB_PORT_TEST=5432
PINGGU_DB_NAME_TEST=pinggu_test
PINGGU_DB_USER_TEST=postgres
PINGGU_DB_PASSWORD_TEST=your_test_password
PINGGU_DB_SSLMODE_TEST=disable

# ======================================
# 生产环境数据库配置
# ======================================
# ⚠️ 生产配置不应提交到版本控制系统
PINGGU_DB_HOST_PROD=10.0.0.100
PINGGU_DB_PORT_PROD=5432
PINGGU_DB_NAME_PROD=pinggu_prod
PINGGU_DB_USER_PROD=pinggu_app
PINGGU_DB_PASSWORD_PROD=your_secure_password
PINGGU_DB_SSLMODE_PROD=require

# ======================================
# 当前使用的数据库配置（根据 APP_ENV 自动切换）
# ======================================
# 以下配置由脚本自动设置，无需手动修改
PINGGU_DB_HOST=${PINGGU_DB_HOST_DEV}
PINGGU_DB_PORT=${PINGGU_DB_PORT_DEV}
PINGGU_DB_NAME=${PINGGU_DB_NAME_DEV}
PINGGU_DB_USER=${PINGGU_DB_USER_DEV}
PINGGU_DB_PASSWORD=${PINGGU_DB_PASSWORD_DEV}
PINGGU_DB_SSLMODE=${PINGGU_DB_SSLMODE_DEV}

# 数据库连接池配置（可选）
PINGGU_DB_POOL_MIN=1
PINGGU_DB_POOL_MAX=10
