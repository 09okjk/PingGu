# ============================================================
# Search History Cases Skill — 环境变量配置示例
# 复制为 .env 并填写真实值
# ============================================================

# ── 数据库连接（必填）─────────────────────────────────────────
PINGGU_DB_HOST=localhost
PINGGU_DB_PORT=5432
PINGGU_DB_NAME=pinggu
PINGGU_DB_USER=pinggu_user
PINGGU_DB_PASSWORD=your_password_here

# ── 连接池（可选，默认值如下）────────────────────────────────
PINGGU_DB_POOL_MIN=1
PINGGU_DB_POOL_MAX=5
PINGGU_DB_CONNECT_TIMEOUT=10

# ── 检索行为（可选，默认值如下）──────────────────────────────
# 默认返回案例数，上层 Agent 可通过 --top-k 参数覆盖
S1_DEFAULT_TOP_K=5

# 粗筛最大候选数
S1_CANDIDATE_LIMIT=20

# 触发条件放宽的最低候选数阈值
# 精确检索候选 < 此值时，自动去掉 service_type_code 条件重查
S1_CANDIDATE_THRESHOLD=5

# 备注相似度最低阈值（低于此值不纳入补充说明）
S1_REMARK_SIM_THRESHOLD=0.1

# 时间衰减区间（年）
# 近 tier1 年内的案例权重最高，tier1~tier2 年次之，更早最低
S1_RECENCY_TIER1_YEARS=2
S1_RECENCY_TIER2_YEARS=3